# GazeControl settings — copy to settings.toml and adjust.
# All values can also be set via environment variables:
#   GAZECONTROL_CAMERA__INDEX=1
#   GAZECONTROL_GAZE__MODEL_MODE=ensemble

[camera]
index = 0
width = 1280
height = 720
fps = 30
warmup_frames = 5

[gaze]
model_mode = "mlp"          # "mlp" | "l2cs" | "ensemble"
strict_l2cs = false         # raise on L2CS load failure instead of warning
ensemble_weight_mlp = 0.7
ensemble_weight_l2cs = 0.3
one_euro_min_cutoff = 1.5
one_euro_beta = 0.007
one_euro_d_cutoff = 1.0

[fixation]
velocity_threshold_deg_s = 30.0
saccade_threshold_deg_s = 100.0
min_fixation_duration_s = 0.1
px_per_deg = 44.0

[drift]
edge_snap_margin_px = 80
implicit_recal_weight = 0.15

[gesture]
model_path = ""              # empty → use rule classifier only
confidence_threshold = 0.6
pinch_release_frames = 3     # consecutive non-PINCH frames required

[intent]
double_pinch_window_s = 0.4
dwell_time_s = 0.8
cooldown_s = 0.3
blink_hold_max_s = 0.4

[overlay]
enabled = true
opacity = 0.85
fps = 30

[paths]
profiles_dir = ""   # empty → platformdirs user_config_dir / gazecontrol / profiles
log_file = ""       # empty → platformdirs user_log_dir / gazecontrol / gazecontrol.log
models_dir = ""     # empty → repo-root / models
